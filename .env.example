# ============================================================
# Ragnar DevOS — Environment Variables Example
# คัดลอกไฟล์นี้เป็น .env และใส่ค่าจริง (ห้าม commit .env)
# ============================================================

# App
APP_ENV=development        # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8050
APP_DEBUG=true

# Database (DuckDB)
DUCKDB_PATH=./data/app.duckdb

# Logging
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# (เพิ่ม environment variables ของ project จริงที่นี่)
